bun = "1.2.19"
deno = "2.5.1"
go = "1.24.3"
node = "lts"
npm = "bundled"
openjdk = "~26"
ruby = "4.0.5"
rust = "1.97.0"
yarn = "1.22.22"
python = "3.14.6"

[settings]
auto-clean = true
auto-install = true
detect-strategy = "prefer-prototools"
pin-latest = "global"
telemetry = false
unstable-lockfile = true

[plugins.tools]
openjdk = "github://eplightning/openjdk-adoptium-proto-plugin"
zig = "github://konomae/zig-plugin"
