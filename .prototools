bun = "1.3.14"
deno = "2.9.2"
go = "1.26.5"
node = "26.5.0"
npm = "bundled"
openjdk = "26.0.1+8"
python = "3.14.6"
ruby = "4.0.5"
rust = "1.97.0"
yarn = "4.17.1"
zig = "0.16.0"

[settings]
auto-clean = true
auto-install = true
detect-strategy = "prefer-prototools"
pin-latest = "global"
telemetry = false
unstable-lockfile = true

[plugins.tools]
openjdk = "github://eplightning/openjdk-adoptium-proto-plugin"
zig = "github://konomae/zig-plugin"
